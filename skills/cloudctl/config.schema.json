{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudctlSkill Configuration Schema",
  "description": "Configuration schema for the Cloud Context & Operations Skill",
  "type": "object",
  "properties": {
    "cloudctl": {
      "type": "object",
      "description": "Core cloudctl configuration",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to cloudctl binary",
          "default": "cloudctl",
          "examples": ["cloudctl", "/usr/local/bin/cloudctl"]
        },
        "timeout_seconds": {
          "type": "integer",
          "description": "Command timeout in seconds",
          "minimum": 1,
          "maximum": 300,
          "default": 30,
          "examples": [30, 60, 120]
        },
        "max_retries": {
          "type": "integer",
          "description": "Maximum retry attempts for transient errors",
          "minimum": 0,
          "maximum": 10,
          "default": 3,
          "examples": [0, 1, 3, 5]
        },
        "verify_context_after_switch": {
          "type": "boolean",
          "description": "Verify context after switch operations",
          "default": true
        },
        "enable_audit_logging": {
          "type": "boolean",
          "description": "Enable audit logging to ~/.config/cloudctl/audit/",
          "default": true
        },
        "dry_run": {
          "type": "boolean",
          "description": "Dry-run mode (no-op, show what would happen)",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "environment_overrides": {
      "type": "object",
      "description": "Environment variable overrides for cloudctl execution",
      "additionalProperties": {
        "type": "string"
      },
      "examples": [
        {
          "AWS_REGION": "eu-west-2",
          "GCLOUD_PROJECT": "my-project"
        }
      ]
    },
    "organizations": {
      "type": "object",
      "description": "Organization-specific configuration overrides",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 300
          },
          "verify_context_after_switch": {
            "type": "boolean"
          },
          "dry_run": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "myorg": {
            "timeout_seconds": 60,
            "verify_context_after_switch": true
          }
        }
      ]
    },
    "cache": {
      "type": "object",
      "description": "Context cache configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable context caching",
          "default": true
        },
        "ttl_seconds": {
          "type": "integer",
          "description": "Cache entry lifetime in seconds",
          "minimum": 1,
          "default": 300
        },
        "max_entries": {
          "type": "integer",
          "description": "Maximum number of cached entries",
          "minimum": 1,
          "default": 100
        }
      },
      "additionalProperties": false
    },
    "features": {
      "type": "object",
      "description": "Feature flags for CloudctlSkill",
      "properties": {
        "auto_refresh_tokens": {
          "type": "boolean",
          "description": "Automatically refresh tokens before expiry",
          "default": true
        },
        "context_caching": {
          "type": "boolean",
          "description": "Cache context for performance",
          "default": true
        },
        "detailed_errors": {
          "type": "boolean",
          "description": "Provide detailed error messages with suggestions",
          "default": true
        },
        "rich_output": {
          "type": "boolean",
          "description": "Use rich console output with colors and emojis",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "security": {
      "type": "object",
      "description": "Security and compliance settings",
      "properties": {
        "min_token_lifetime": {
          "type": "integer",
          "description": "Minimum token lifetime before refresh (seconds)",
          "minimum": 1,
          "default": 300
        },
        "audit_sensitive_operations": {
          "type": "boolean",
          "description": "Audit sensitive operations (account/role changes)",
          "default": true
        },
        "mask_sensitive_data": {
          "type": "boolean",
          "description": "Mask sensitive data in logs",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "level": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"],
          "default": "INFO"
        },
        "format": {
          "type": "string",
          "enum": ["json", "text"],
          "default": "text"
        },
        "file": {
          "type": "string",
          "description": "Log file path (~/ supported)",
          "default": "~/.config/cloudctl/skill.log"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true,
  "examples": [
    {
      "cloudctl": {
        "path": "cloudctl",
        "timeout_seconds": 30,
        "max_retries": 3,
        "verify_context_after_switch": true,
        "enable_audit_logging": true,
        "dry_run": false
      },
      "features": {
        "auto_refresh_tokens": true,
        "context_caching": true,
        "detailed_errors": true,
        "rich_output": true
      }
    },
    {
      "cloudctl": {
        "path": "/usr/local/bin/cloudctl",
        "timeout_seconds": 60,
        "max_retries": 5,
        "enable_audit_logging": true,
        "dry_run": false
      },
      "environment_overrides": {
        "AWS_REGION": "eu-west-2",
        "GCLOUD_PROJECT": "my-gcp-project"
      }
    }
  ]
}
